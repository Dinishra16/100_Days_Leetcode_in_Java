class Solution:
    def longestPalindrome(self, s: str) -> str:

        ans = "" #ans stores the longest palindrome found so far

        for i in range(len(s)):
            left = i               #b a b a d  Both pointers start at the same character.
            right = i              #    ^
                                   #  left
                                   #  right  
            while left >= 0 and right < len(s) and s[left] == s[right]:
                if len(s[left:right+1]) > len(ans):
                    ans = s[left:right+1]
                left -= 1
                right += 1

            # Even-length palindrome
            left = i
            right = i + 1
            while left >= 0 and right < len(s) and s[left] == s[right]:
                if len(s[left:right+1]) > len(ans):
                    ans = s[left:right+1]
                left -= 1
                right += 1

        return ans
